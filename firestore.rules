rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Perfil del Psicólogo: Lectura pública (para agendar.html), Escritura reservada al dueño.
    match /psicologos/{psicologoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == psicologoId;
    }
    
    // 2. Subcolecciones privadas (Pacientes, Historial Clínico, Citas, etc.):
    // Acceso exclusivo al psicólogo autenticado dueño de la cuenta.
    match /psicologos/{psicologoId}/{subcollection}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == psicologoId;
    }
  }
}
